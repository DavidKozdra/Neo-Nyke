#!/bin/sh

if ! command -v node >/dev/null 2>&1; then
  echo "pre-commit: Node.js is not available in Git's PATH." >&2
  exit 1
fi

node scripts/generate-precache.js || exit $?
git add -- sw.js || exit $?
node scripts/generate-precache.js --check || exit $?
node scripts/check-i18n.js --strict || exit $?
exec node scripts/run-tests.js
