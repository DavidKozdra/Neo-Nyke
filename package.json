{
  "name": "neonyke",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prepare": "node scripts/install-git-hooks.js",
    "icons": "node generate-icons.js",
    "test": "node scripts/run-tests.js",
    "i18n:check": "node scripts/check-i18n.js --strict",
    "i18n:check:structure": "node scripts/check-i18n.js",
    "i18n:check:strict": "node scripts/check-i18n.js --strict",
    "i18n:fill": "node scripts/fill-i18n-translations.js",
    "i18n:sync": "node scripts/sync-i18n-content.js",
    "start": "python3 -m http.server 5173",
    "start:py": "python -m http.server 5173",
    "editor": "node server/editor-server.js",
    "multiplayer:local": "node scripts/run-local-multiplayer-harness.js",
    "multiplayer:dev": "npm run build && server/node_modules/.bin/wrangler dev --config wrangler.toml",
    "multiplayer:smoke": "node scripts/smoke-cloudflare-multiplayer.js",
    "build": "rm -rf dist && mkdir -p dist && cp -r index.html game.html sw.js manifest.json css js assets Koz_Engine_Lib dist/"
  },
  "devDependencies": {
    "canvas": "^3.2.3",
    "jest": "^30.4.2",
    "playwright": "^1.61.0",
    "terser": "^5.0.0"
  },
  "dependencies": {
    "three": "^0.185.1"
  }
}
